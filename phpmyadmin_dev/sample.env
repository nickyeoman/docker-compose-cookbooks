# ===== Paths =====
VOL_PATH=/data
VOL_PROJECTS=/data/projects

# ===== phpMyAdmin =====
PHPMYADMIN_IMAGE=phpmyadmin/phpmyadmin:latest
PHPMYADMIN_RESTART=unless-stopped
PHPMYADMIN_PORT=8083
PHPMYADMIN_PMA_ARBITRARY=1
PHPMYADMIN_PMA_HOST=mariadb
PHPMYADMIN_PMA_USER=root
PHPMYADMIN_PMA_PASSWORD=ChangeThisPassword
PHPMYADMIN_UPLOAD_LIMIT=200M

# Compose
VOL_PATH=/data
ZAMMAD_IMAGE=ghcr.io/zammad/zammad:latest
ZAMMAD_RESTART=always
ZAMMAD_PORT=8080

# PostgreSQL
POSTGRES_VERSION=17.5-alpine
POSTGRES_DB=zammad_production
POSTGRES_USER=zammad
POSTGRES_PASS=zammad

# Redis
REDIS_VERSION=7.4.5-alpine

# Memcached
MEMCACHE_VERSION=1.6.39-alpine

# Elasticsearch
ELASTICSEARCH_VERSION=8.19.2
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_JAVA_OPTS=-Xms1g -Xmx1g

# Zammad
TZ=America/Vancouver
NGINX_PORT=8080
NGINX_SERVER_NAME=_

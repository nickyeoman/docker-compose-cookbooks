# Compose
VOL_PATH=/data
INVOICENINJA_IMAGE=invoiceninja/invoiceninja-debian:latest
INVOICENINJA_RESTART=unless-stopped
INVOICENINJA_PORT=8000
MYSQL_IMAGE=mysql:8
NGINX_IMAGE=nginx:alpine
REDIS_IMAGE=redis:alpine

# IN application vars
APP_URL=http://localhost:8000
# echo -n "base64:$(openssl rand -base64 32)"
APP_KEY=ChangeThisPassword
APP_ENV=production
APP_DEBUG=true
REQUIRE_HTTPS=false
PHANTOMJS_PDF_GENERATION=false
PDF_GENERATOR=snappdf
TRUSTED_PROXIES='*'


CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

FILESYSTEM_DISK=debian_docker

# DB connection
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ninja
DB_USERNAME=ninja
DB_PASSWORD=ChangeThisPassword
DB_ROOT_PASSWORD=ChangeThisPassword
DB_CONNECTION=mysql


# Create initial user
# Default to these values if empty
IN_USER_EMAIL=admin@example.com
IN_PASSWORD=ChangeThisPassword
# IN_USER_EMAIL=
# IN_PASSWORD=

# Mail options
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS='user@example.com'
MAIL_FROM_NAME='Self Hosted User'


# GoCardless/Nordigen API key for banking integration
NORDIGEN_SECRET_ID=ChangeThisPassword
NORDIGEN_SECRET_KEY=ChangeThisPassword

IS_DOCKER=true
SCOUT_DRIVER=null
#SNAPPDF_CHROMIUM_PATH=/usr/bin/google-chrome-stable



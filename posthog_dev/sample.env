# Compose
VOL_PATH=/data
POSTHOG_IMAGE=posthog/posthog:latest
POSTHOG_RESTART=unless-stopped

# Core
POSTHOG_SITE_URL=http://localhost:8000
POSTHOG_SECRET_KEY=ChangeThisPassword

# Database
POSTHOG_DB_NAME=posthog
POSTHOG_DB_USER=posthog
POSTHOG_DB_PASSWORD=ChangeThisPassword

# ClickHouse
POSTHOG_CLICKHOUSE_DB=posthog
POSTHOG_CLICKHOUSE_USER=clickhouse
POSTHOG_CLICKHOUSE_PASSWORD=ChangeThisPassword

# Email (optional)
POSTHOG_EMAIL_HOST=
POSTHOG_EMAIL_USER=
POSTHOG_EMAIL_PASSWORD=ChangeThisPassword
POSTHOG_EMAIL_PORT=587
POSTHOG_EMAIL_TLS=true
POSTHOG_CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:24-alpine
POSTHOG_KAFKA_IMAGE=docker.io/bitnami/kafka:3.7
POSTHOG_PORT=8000
POSTHOG_POSTGRES_IMAGE=postgres:15-alpine
POSTHOG_REDIS_IMAGE=redis:7-alpine
